#!/usr/bin/env python3
import sys
import os
import subprocess
import signal
import time

# Simple wrapper to manage the honeypot process
# In a real Cowrie installation, this interacts with twistd, here we manage python3 main.py

PID_FILE = "var/run/cyanide.pid"
STDOUT_LOG = "var/log/cyanide/cyanide.out"
STDERR_LOG = "var/log/cyanide/cyanide.err"

def start():
    # Ensure dirs exist
    os.makedirs(os.path.dirname(PID_FILE), exist_ok=True)
    os.makedirs(os.path.dirname(STDOUT_LOG), exist_ok=True)

    if os.path.exists(PID_FILE):
        print("Cyanide already running (pid file exists).")
        return

    # Load and print configuration info
    try:
        sys.path.append(os.path.join(os.getcwd(), 'src'))
        from cyanide.core.config import load_config
        from pathlib import Path
        
        config = load_config(Path("config/cyanide.cfg"))
        if config:
            print("\n" + "="*50)
            print(" CYANIDE HONEYPOT STARTUP INFO")
            print("="*50)
            
            # Network info
            bind_ip = "0.0.0.0" # Default 
            print(f"[*] Bind Address:   {bind_ip}")
            
            if config.get('ssh', {}).get('enabled'):
                print(f"[*] SSH Port:       {config['ssh']['port']}")
                
            if config.get('telnet', {}).get('enabled'):
                print(f"[*] Telnet Port:    {config['telnet']['port']}")
                
            # User info
            users = [u['user'] for u in config.get('users', [])]
            print(f"[*] Available Users: {', '.join(users)}")
            print("="*50 + "\n")
            
    except Exception as e:
        print(f"[!] Info: Could not load extra config info: {e}")

    print("Starting Cyanide...")
    # Adjust python path to include src
    env = os.environ.copy()
    env["PYTHONPATH"] = os.path.join(os.getcwd(), "src")
    
    # We execute main.py in the background
    # Redirect output to a log file or /dev/null
    with open(STDOUT_LOG, "w") as out, open(STDERR_LOG, "w") as err:
        p = subprocess.Popen(
            [sys.executable, "src/cyanide/main.py"], 
            cwd=os.getcwd(),
            env=env,
            stdout=out, 
            stderr=err
        )
    
    with open(PID_FILE, "w") as f:
        f.write(str(p.pid))
    print(f"Cyanide started with PID {p.pid}")

def stop():
    if not os.path.exists(PID_FILE):
        print("Cyanide not running.")
        return
        
    with open(PID_FILE, "r") as f:
        pid = int(f.read().strip())
    
    print(f"Stopping Cyanide (PID {pid})...")
    try:
        os.kill(pid, signal.SIGTERM)
        # Wait for it to die
        time.sleep(1)
    except ProcessLookupError:
        print("Process not found.")
    
    os.remove(PID_FILE)
    print("Stopped.")

def stats():
    import requests
    from datetime import timedelta

    # Get port from config if possible
    port = 9090 # Default fallback
    try:
        sys.path.append(os.path.join(os.getcwd(), 'src'))
        from cyanide.core.config import load_config
        from pathlib import Path
        config = load_config(Path("config/cyanide.cfg"))
        port = int(config.get("metrics", {}).get("port", 9090))
    except Exception as e:
        print(f"\033[1;33m[!] Warning: Could not load config for stats port: {e}\033[0m", file=sys.stderr)

    try:
        url = f"http://localhost:{port}/stats"
        response = requests.get(url, timeout=5)
        response.raise_for_status()
        data = response.json()
        
        print("\n" + "\033[1;36m" + "="*50 + "\033[0m")
        print("\033[1;36m CYANIDE HONEYPOT STATISTICS\033[0m")
        print("\033[1;36m" + "="*50 + "\033[0m")
        
        uptime = data.get('uptime_seconds', 0)
        print(f"[*] Uptime:          {timedelta(seconds=uptime)}")
        print(f"[*] Active Sessions: \033[1;32m{data.get('active_sessions', 0)}\033[0m")
        print(f"[*] Total Sessions:  {data.get('total_sessions', 0)}")
        print(f"[*] Malware Scans:   {data.get('malware_scans', 0)} (Detected: \033[1;31m{data.get('malicious_detected', 0)}\033[0m)")
        
        if data.get('top_ips'):
            print("\n\033[1;33m--- Top Attacker IPs ---\033[0m")
            for ip, count in data['top_ips'].items():
                print(f" {ip:<20} | {count} hits")
            
        if data.get('recent_commands'):
            print("\n\033[1;33m--- Recent Commands ---\033[0m")
            for cmd in data['recent_commands']:
                t = time.strftime('%H:%M:%S', time.localtime(cmd.get('timestamp', time.time())))
                print(f" [{t}] {cmd.get('ip', 'unknown'):<15} ({cmd.get('username', 'unknown')}): {cmd.get('command', '')}")
        
        print("\033[1;36m" + "="*50 + "\033[0m\n")

    except requests.exceptions.ConnectionError:
        print(f"\033[1;31m[!] Error: Could not connect to Cyanide at {url}\033[0m")
        print("    Ensure the honeypot is running and metrics are enabled in config/cyanide.cfg")
    except requests.exceptions.Timeout:
        print(f"\033[1;31m[!] Error: Request to {url} timed out after 5 seconds\033[0m")
    except requests.exceptions.RequestException as e:
        print(f"\033[1;31m[!] Error fetching stats: {e}\033[0m")
    except Exception as e:
        print(f"\033[1;31m[!] Unexpected error: {e}\033[0m")


def usage():
    print("Usage: bin/cyanide {start|stop|restart|stats}")
    sys.exit(1)

def main():
    if len(sys.argv) < 2:
        usage()
        
    cmd = sys.argv[1]
    if cmd == "start":
        start()
    elif cmd == "stop":
        stop()
    elif cmd == "restart":
        stop()
        start()
    elif cmd == "stats":
        stats()
    else:
        usage()

if __name__ == "__main__":
    main()
